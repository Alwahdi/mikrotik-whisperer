    },
    {
      "page": "/dashboard",
      "regex": "^/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard(?:/)?$"
    },
    {
      "page": "/health",
      "regex": "^/health(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/health(?:/)?$"
    },
    {
      "page": "/hotspot",
      "regex": "^/hotspot(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/hotspot(?:/)?$"
    },
    {
      "page": "/loading",
      "regex": "^/loading(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/loading(?:/)?$"
    },
    {
      "page": "/routers",
      "regex": "^/routers(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/routers(?:/)?$"
    },
    {
      "page": "/sales",
      "regex": "^/sales(?:/)?$",
