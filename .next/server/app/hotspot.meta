{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/hotspot/layout,_N_T_/hotspot/page,_N_T_/hotspot"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/hotspot/__PAGE__",
    "/hotspot",
    "/_index",
    "/_head"
  ]
}