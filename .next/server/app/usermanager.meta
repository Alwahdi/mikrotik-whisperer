{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/usermanager/layout,_N_T_/usermanager/page,_N_T_/usermanager"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/usermanager/__PAGE__",
    "/usermanager",
    "/_index",
    "/_head"
  ]
}