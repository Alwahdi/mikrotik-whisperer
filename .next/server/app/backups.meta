{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/backups/layout,_N_T_/backups/page,_N_T_/backups"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/backups/__PAGE__",
    "/backups",
    "/_index",
    "/_head"
  ]
}