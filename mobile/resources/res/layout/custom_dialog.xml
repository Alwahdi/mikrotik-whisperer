<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:lgrupo="http://schemas.android.com/apk/lib/com.blogspot.yemeninfo4it.mumsmobile_app" xmlns:aapt="http://schemas.android.com/aapt" android:gravity="center" android:id="@+id/cp_bg_view" android:background="#00000000" android:layout_width="match_parent" android:layout_height="match_parent" android:layoutDirection="rtl">
    <androidx.cardview.widget.CardView android:id="@+id/cp_cardview" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="150dp" android:minHeight="140dp" app:cardBackgroundColor="#00000000" app:cardCornerRadius="16dp" app:cardElevation="0dp" app:cardMaxElevation="0dp">
