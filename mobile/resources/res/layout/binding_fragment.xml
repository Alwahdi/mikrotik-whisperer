<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:lgrupo="http://schemas.android.com/apk/lib/com.blogspot.yemeninfo4it.mumsmobile_app" xmlns:aapt="http://schemas.android.com/aapt" android:id="@+id/fragment_container" android:background="@color/gry" android:focusableInTouchMode="true" android:layout_width="match_parent" android:layout_height="match_parent" android:layoutDirection="rtl">
    <androidx.core.widget.NestedScrollView android:id="@+id/scroll" android:layout_width="match_parent" android:layout_height="match_parent" app:layout_behavior="@string/appbar_scrolling_view_behavior">
        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
            <LinearLayout android:orientation="vertical" android:fitsSystemWindows="true" android:layout_width="match_parent" android:layout_height="match_parent">
                <LinearLayout android:gravity="center" android:orientation="vertical" android:id="@+id/table_test_container" android:paddingBottom="20dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <com.blogspot.yemeninfo4it.mumsmobile_app.MyHorizScrollView android:scrollbarTrackHorizontal="@color/mainColor" android:scrollbarStyle="insideInset" android:gravity="center" android:layout_gravity="center" android:scrollbars="none|horizontal|vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
                        <LinearLayout android:gravity="center" android:layout_gravity="center" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
                            <LinearLayout android:gravity="center" android:layout_gravity="center" android:orientation="horizontal" android:id="@+id/search_field" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="15dp">
                                <Button android:textSize="15sp" android:textStyle="bold" android:textColor="#ffffff" android:id="@+id/activebtn" android:background="@drawable/rect_blue" android:layout_width="wrap_content" android:layout_height="41dp" android:layout_marginTop="5dp" android:layout_marginBottom="10dp" android:text="تحميل" android:textAllCaps="false" android:paddingStart="35dp" android:paddingEnd="35dp"/>
                                <Button android:textSize="16.5sp" android:textStyle="bold" android:textColor="#ffffff" android:id="@+id/showbtn" android:background="@drawable/rect_blue" android:paddingLeft="28dp" android:paddingRight="28dp" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:layout_marginBottom="5dp" android:text="إظهار" android:textAllCaps="false"/>
                                <Button android:textSize="16.5sp" android:textStyle="bold" android:textColor="#ffffff" android:id="@+id/dubl" android:background="@drawable/rect_blue" android:paddingLeft="20dp" android:paddingRight="20dp" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:layout_marginBottom="5dp" android:text="حذف التكرار" android:textAllCaps="false"/>
                                <TextView android:textSize="15sp" android:textStyle="bold" android:textColor="@color/black" android:id="@+id/sum" android:padding="10dp" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="80dp" android:text="المجموع"/>
                                <TextView android:textSize="15sp" android:textStyle="bold" android:textColor="@color/black" android:id="@+id/activeacount" android:padding="10dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="العدد" android:layout_marginStart="10sp"/>
                            </LinearLayout>
                            <TextView android:textSize="13sp" android:textStyle="bold" android:textColor="@color/colorPrimaryDark" android:padding="10dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="80dp" android:text="@string/click_on_row"/>
                        </LinearLayout>
                    </com.blogspot.yemeninfo4it.mumsmobile_app.MyHorizScrollView>
                    <HorizontalScrollView android:id="@+id/horizontalView" android:visibility="gone" android:scrollbars="none|horizontal|vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
                        <LinearLayout android:gravity="center" android:orientation="horizontal" android:background="@drawable/btn_back" android:layout_width="wrap_content" android:layout_height="wrap_content">
                            <TextView android:textSize="14dp" android:textStyle="bold" android:textColor="@color/black" android:padding="10dp" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="80dp" android:text="ID"/>
                            <TextView android:textSize="14dp" android:textStyle="bold" android:textColor="@color/black" android:padding="10dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="80dp" android:text="اسم المستخدم"/>
                            <TextView android:textSize="14dp" android:textStyle="bold" android:textColor="@color/black" android:padding="10dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="80dp" android:text="مدة الاتصال"/>
                            <TextView android:textSize="14dp" android:textStyle="bold" android:textColor="@color/black" android:padding="10dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="80dp" android:text="الوقت المتبقي"/>
                            <TextView android:textSize="14dp" android:textStyle="bold" android:textColor="@color/black" android:padding="10dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="80dp" android:text="ايبي"/>
                            <TextView android:textSize="14dp" android:textStyle="bold" android:textColor="@color/black" android:padding="10dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="80dp" android:text="تحميل"/>
                            <TextView android:textSize="14dp" android:textStyle="bold" android:textColor="@color/black" android:padding="10dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="80dp" android:text="الرفع"/>
                        </LinearLayout>
                    </HorizontalScrollView>
                </LinearLayout>
                <LinearLayout android:gravity="center" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_below="@+id/table_test_container">
                    <com.evrencoskun.tableview.TableView android:layout_gravity="center" android:id="@+id/tableview_binding" android:layout_width="match_parent" android:layout_height="match_parent" app:selected_color="@color/colorPrimaryDark" app:shadow_color="#eee" app:unselected_color="@color/white"/>
                </LinearLayout>
                <androidx.recyclerview.widget.RecyclerView android:scrollbarStyle="outsideOverlay" android:id="@+id/recycleractive" android:paddingBottom="5dp" android:visibility="gone" android:scrollbars="none|horizontal|vertical" android:clickable="true" android:layout_width="match_parent" android:layout_height="270dp" android:layout_marginLeft="2dp" android:layout_marginRight="2dp" android:minHeight="250dp" android:nestedScrollingEnabled="true" app:reverseLayout="true"/>
            </LinearLayout>
        </RelativeLayout>
    </androidx.core.widget.NestedScrollView>
</RelativeLayout>
