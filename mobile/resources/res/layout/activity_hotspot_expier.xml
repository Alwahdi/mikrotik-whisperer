<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:lgrupo="http://schemas.android.com/apk/lib/com.blogspot.yemeninfo4it.mumsmobile_app" xmlns:aapt="http://schemas.android.com/aapt" android:focusable="true" android:focusableInTouchMode="true" android:layout_width="match_parent" android:layout_height="match_parent" android:layoutDirection="rtl">
    <LinearLayout android:orientation="vertical" android:id="@+id/mtool" android:layout_width="match_parent" android:layout_height="wrap_content">
        <include layout="@layout/toolbar_act"/>
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="5sp" app:cardBackgroundColor="@color/white" app:cardCornerRadius="10sp" app:cardElevation="3sp">
            <LinearLayout android:orientation="vertical" android:paddingTop="2sp" android:paddingBottom="3sp" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingStart="5sp" android:paddingEnd="5sp" android:elevation="5sp">
                <LinearLayout android:gravity="center" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:layout_marginBottom="4dp">
                    <TextView android:textSize="14sp" android:textColor="@color/colorPrimary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="10dp" android:layout_marginRight="10dp" android:text="حذف الكروت المنتهية على حسب : "/>
                </LinearLayout>
                <LinearLayout android:gravity="center" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp">
                    <RadioButton android:textSize="14sp" android:textColor="@color/white" android:id="@+id/transmation_limitRadio" android:background="@drawable/select_draw_new" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" android:button="@android:color/transparent" android:text="كمية التحميل" android:layout_marginStart="5dp" android:layout_marginEnd="5dp" android:elevation="5sp"/>
                    <RadioButton android:textSize="14sp" android:id="@+id/houer_limitRadio" android:background="@drawable/select_draw_new" android:layout_width="wrap_content" android:layout_height="wrap_content" android:button="@android:color/transparent" android:text="عدد الساعات" android:layout_marginStart="5dp" android:layout_marginEnd="5dp" android:elevation="5sp"/>
                    <RadioButton android:textSize="14sp" android:id="@+id/disabled_cardRadio" android:background="@drawable/select_draw_new" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="3sp" android:layout_marginBottom="3sp" android:button="@android:color/transparent" android:text="المعطلة او منتهية الصلاحية" android:layout_marginStart="5dp" android:layout_marginEnd="5dp" android:elevation="5sp"/>
                </LinearLayout>
                <LinearLayout android:gravity="center" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="7dp">
                    <TextView android:textSize="13sp" android:textStyle="bold" android:textColor="@color/colorPrimary" android:id="@+id/title_txt" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="اكتب كمية التحميل للباقة " android:layout_marginStart="7dp" android:layout_marginEnd="5dp"/>
                </LinearLayout>
                <LinearLayout android:gravity="center" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="3dp">
                    <LinearLayout android:gravity="center" android:orientation="horizontal" android:id="@+id/trans_layout" android:visibility="visible" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.3">
                        <EditText android:textSize="15sp" android:textColor="@color/black" android:textColorHint="@color/gray" android:id="@+id/transmation_limit_txt" android:background="@drawable/rect" android:padding="4dp" android:layout_width="140dp" android:layout_height="wrap_content" android:hint="اكتب كمية التحميل" android:maxLines="1" android:singleLine="true" android:inputType="number" android:textAlignment="center" android:layout_marginStart="7dp" android:layout_marginEnd="7dp"/>
                        <TextView android:textSize="12.5sp" android:textColor="@color/mainColorDark" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ميجا"/>
                    </LinearLayout>
                    <LinearLayout android:gravity="center" android:orientation="vertical" android:id="@+id/houer_layout" android:visibility="gone" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.3">
                        <LinearLayout android:gravity="center" android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="wrap_content">
                            <EditText android:textSize="13.5sp" android:id="@+id/houer_limit_txt" android:background="@drawable/rect" android:padding="4dp" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginLeft="7dp" android:layout_marginRight="7dp" android:minWidth="90dp" android:hint="عدد الساعات" android:layout_weight="0.3" android:inputType="number" android:textAlignment="center"/>
                            <TextView android:textSize="12dp" android:textColor="@color/mainColorDark" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ساعة"/>
                            <EditText android:textSize="13.5sp" android:id="@+id/time_menut_txt" android:background="@drawable/rect" android:padding="4dp" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginLeft="7dp" android:layout_marginRight="7dp" android:minWidth="90dp" android:hint="عدد الدقائق" android:layout_weight="0.3" android:inputType="number" android:textAlignment="center"/>
                            <TextView android:textSize="12dp" android:textColor="@color/mainColorDark" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="دقيقة"/>
                        </LinearLayout>
                        <TextView android:textSize="12dp" android:textColor="@color/mainColorDark" android:id="@+id/time_description" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=".."/>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout android:gravity="center" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="15dp">
                    <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="#ffffff" android:layout_gravity="start" android:id="@+id/show_user_btn" android:background="@drawable/rect_blue" android:paddingLeft="13dp" android:paddingTop="6dp" android:paddingRight="13dp" android:paddingBottom="6dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="10dp" android:layout_marginRight="10dp" android:layout_marginBottom="2dp" android:text="إظهار الكروت المنتهية" android:textAllCaps="false"/>
                </LinearLayout>
                <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp">
                    <androidx.appcompat.widget.AppCompatCheckBox android:textSize="12sp" android:textStyle="bold" android:textColor="@color/mainColor" android:id="@+id/chk_select_all" android:layout_width="95dp" android:layout_height="wrap_content" android:text="تحديد الكل" app:buttonTint="@color/mainColor"/>
                    <Button android:textSize="13sp" android:textStyle="bold" android:textColor="#ffffff" android:layout_gravity="start" android:id="@+id/btn_delete_all" android:background="@drawable/loginbutton_selector" android:layout_width="wrap_content" android:layout_height="37dp" android:layout_margin="1.5dp" android:text="@string/delete_selected" android:textAllCaps="false" android:drawableEnd="@drawable/delete_icon" android:paddingStart="8dp" android:paddingEnd="8dp"/>
                    <TextView android:textSize="13sp" android:textStyle="bold" android:textColor="#000" android:id="@+id/count_txt" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="1dp" android:layout_marginBottom="3dp" android:layout_weight="1" android:layout_marginEnd="1dp"/>
                </LinearLayout>
                <LinearLayout android:gravity="center" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="1dp" android:layout_marginBottom="2sp" android:layout_marginStart="10sp" android:layout_marginEnd="10sp">
                    <TextView android:textSize="13sp" android:textStyle="bold" android:textColor="@color/mainColorDark" android:id="@+id/deleted_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="1dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
    <HorizontalScrollView android:scrollbars="none|horizontal|vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:layout_below="@+id/mtool">
        <LinearLayout android:gravity="center" android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="wrap_content">
            <ListView android:id="@+id/myCustomListView" android:scrollbars="none|horizontal|vertical" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_below="@+id/mySearchView"/>
        </LinearLayout>
    </HorizontalScrollView>
</RelativeLayout>
