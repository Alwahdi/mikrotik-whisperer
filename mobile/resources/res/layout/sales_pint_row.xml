<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:lgrupo="http://schemas.android.com/apk/lib/com.blogspot.yemeninfo4it.mumsmobile_app" xmlns:aapt="http://schemas.android.com/aapt" android:orientation="vertical" android:layout_width="wrap_content" android:layout_height="match_parent" android:layoutDirection="rtl">
    <LinearLayout android:orientation="vertical" android:id="@+id/title" android:background="#eee" android:layout_width="match_parent" android:layout_height="wrap_content">
        <LinearLayout android:orientation="horizontal" android:paddingTop="10dp" android:paddingBottom="10dp" android:layout_width="wrap_content" android:layout_height="wrap_content">
            <TextView android:textSize="15sp" android:textStyle="bold" android:textColor="@color/black" android:id="@+id/sls_id_tit" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="50dp" android:text="id" android:textAlignment="center" android:layout_marginStart="5dp" android:layout_marginEnd="5dp"/>
            <TextView android:textSize="15sp" android:textStyle="bold" android:textColor="@color/black" android:id="@+id/sls_name_tit" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="100dp" android:text="اسم نقطة البيع" android:textAlignment="center" android:layout_marginStart="5dp" android:layout_marginEnd="5dp"/>
            <TextView android:textSize="15sp" android:textStyle="bold" android:textColor="@color/black" android:id="@+id/used_count_tit" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="120dp" android:text="كروت مستخدمة" android:textAlignment="center" android:layout_marginStart="5dp" android:layout_marginEnd="5dp"/>
            <TextView android:textSize="15sp" android:textStyle="bold" android:textColor="@color/black" android:id="@+id/unused_count_tit" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="120dp" android:text="كروت غير مستخدمة" android:textAlignment="center" android:layout_marginStart="5dp" android:layout_marginEnd="5dp"/>
            <TextView android:textSize="15sp" android:textStyle="bold" android:textColor="@color/black" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="90dp" android:text="المجموع" android:textAlignment="center" android:layout_marginStart="2dp" android:layout_marginEnd="2dp"/>
        </LinearLayout>
        <View android:id="@+id/vv" android:background="#4b4b4b" android:layout_width="match_parent" android:layout_height="2dp"/>
    </LinearLayout>
    <LinearLayout android:orientation="horizontal" android:paddingTop="7dp" android:paddingBottom="7dp" android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView android:textSize="14sp" android:textColor="@color/md_material_blue_800" android:id="@+id/sls_id" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:layout_marginBottom="2dp" android:minWidth="50dp" android:text="__" android:textDirection="rtl" android:textAlignment="center" android:layout_marginStart="5dp" android:layout_marginEnd="5dp"/>
        <TextView android:textSize="14sp" android:textColor="@color/md_material_blue_800" android:id="@+id/sls_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:layout_marginBottom="2dp" android:minWidth="100dp" android:text="لا توجد بيانات" android:textAlignment="center" android:layout_marginStart="5dp" android:layout_marginEnd="5dp"/>
        <TextView android:textSize="14sp" android:textColor="@color/md_material_blue_800" android:id="@+id/used_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:layout_marginBottom="2dp" android:minWidth="120dp" android:text="0" android:textAlignment="center" android:layout_marginStart="5dp" android:layout_marginEnd="5dp"/>
        <TextView android:textSize="14sp" android:textColor="@color/md_material_blue_800" android:id="@+id/unused_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:layout_marginBottom="2dp" android:minWidth="120dp" android:text="0" android:textAlignment="center" android:layout_marginStart="5dp" android:layout_marginEnd="5dp"/>
        <TextView android:textSize="14sp" android:textColor="@color/md_material_blue_800" android:id="@+id/total_s" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:layout_marginBottom="2dp" android:minWidth="90dp" android:text="0" android:textAlignment="center" android:layout_marginStart="2dp" android:layout_marginEnd="2dp"/>
    </LinearLayout>
    <View android:background="#cacaca" android:layout_width="match_parent" android:layout_height="1dp"/>
</LinearLayout>
