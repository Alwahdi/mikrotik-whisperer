<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:lgrupo="http://schemas.android.com/apk/lib/com.blogspot.yemeninfo4it.mumsmobile_app" xmlns:aapt="http://schemas.android.com/aapt" android:orientation="vertical" android:background="@drawable/rect_grey" android:padding="0sp" android:layout_width="match_parent" android:layout_height="match_parent" android:fillViewport="true" android:layoutDirection="rtl">
    <RelativeLayout android:padding="0sp" android:focusable="true" android:focusableInTouchMode="true" android:layout_width="match_parent" android:layout_height="wrap_content">
        <LinearLayout android:orientation="vertical" android:id="@+id/header" android:layout_width="match_parent" android:layout_height="match_parent">
            <View android:id="@+id/topView" android:background="#e46665" android:layout_width="match_parent" android:layout_height="105sp"/>
            <ImageView android:layout_width="match_parent" android:layout_height="115sp" android:scaleType="centerCrop" app:srcCompat="@drawable/wave"/>
            <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>
        </LinearLayout>
        <ImageView android:id="@+id/app_logo" android:layout_width="155dp" android:layout_height="119dp" android:layout_marginTop="35dp" android:layout_marginBottom="5dp" android:src="@drawable/logonew" android:scaleType="fitXY" android:layout_centerHorizontal="true" android:contentDescription="دخول"/>
        <LinearLayout android:gravity="bottom" android:layout_gravity="bottom" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="18dp" android:layout_marginTop="35sp" android:layout_marginRight="18dp" android:layout_marginBottom="15dp" android:layout_below="@+id/app_logo">
            <TextView android:textSize="20sp" android:textStyle="bold" android:textColor="@color/white" android:layout_gravity="center" android:id="@+id/back_imgf" android:visibility="visible" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5sp" android:layout_marginBottom="10dp" android:text="تسجيل الدخول بالبرنامج"/>
            <TextView android:textAppearance="?android:attr/textAppearanceLarge" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/white" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="1dp" android:layout_marginBottom="5dp" android:text="قُم بكتابة رقم الموبايل وكلمة السر الخاصة بحسابك بالبرنامج" android:layout_marginStart="5sp" android:layout_marginEnd="5sp"/>
            <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="5dp" android:layout_marginRight="5dp" android:layout_marginBottom="5dp">
                <LinearLayout android:orientation="vertical" android:background="@drawable/blue_leftcorner_bkg" android:layout_width="55dp" android:layout_height="wrap_content">
                    <LinearLayout android:gravity="center" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="50dp">
                        <ImageView android:layout_width="30dp" android:layout_height="30dp" android:src="@drawable/phone" android:scaleType="fitCenter"/>
                    </LinearLayout>
                    <LinearLayout android:orientation="vertical" android:background="#f1f1f1" android:layout_width="match_parent" android:layout_height="1dp"/>
                    <LinearLayout android:gravity="center" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="50dp">
                        <ImageView android:layout_width="35dp" android:layout_height="35dp" android:src="@drawable/user" android:scaleType="fitCenter"/>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout android:orientation="vertical" android:background="@drawable/white_rightcorner_bkg" android:layout_width="match_parent" android:layout_height="match_parent">
                    <LinearLayout android:orientation="horizontal" android:visibility="gone" android:layout_width="match_parent" android:layout_height="55dp">
                        <RelativeLayout android:visibility="gone" android:layout_width="match_parent" android:layout_height="55dp" android:layout_marginBottom="15dp">
                            <ImageView android:id="@+id/countryImage2" android:layout_width="20dp" android:layout_height="20dp" android:layout_centerVertical="true" android:layout_marginStart="10dp" android:layout_marginEnd="10dp" app:srcCompat="@drawable/ic_user"/>
                            <EditText android:textSize="15dp" android:id="@+id/name" android:background="@null" android:layout_width="match_parent" android:layout_height="match_parent" android:hint="الاسم" android:maxLines="1" android:layout_alignParentBottom="true" android:imeOptions="actionNext" android:textAlignment="center" android:paddingStart="20dp" android:paddingEnd="20dp"/>
                        </RelativeLayout>
                    </LinearLayout>
                    <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="50dp">
                        <RelativeLayout android:layout_width="match_parent" android:layout_height="48dp">
                            <ImageView android:id="@+id/countryImage" android:layout_width="27dp" android:layout_height="27dp" android:src="@drawable/flag_ye" android:layout_centerVertical="true" android:layout_marginStart="8sp"/>
                            <EditText android:textSize="13sp" android:gravity="center" android:id="@+id/countryNumber" android:layout_width="wrap_content" android:layout_height="match_parent" android:layout_marginLeft="6dp" android:text="+967" android:editable="false" android:layout_alignParentBottom="true" android:layout_marginStart="6dp" android:layout_toEndOf="@+id/countryImage"/>
                            <EditText android:textSize="15sp" android:id="@+id/ed_mobile_number" android:background="@null" android:layout_width="match_parent" android:layout_height="match_parent" android:hint="رقم الموبايل" android:maxLines="1" android:layout_alignParentBottom="true" android:inputType="phone" android:imeOptions="actionNext" android:textAlignment="center" android:paddingStart="10dp" android:paddingEnd="10dp" android:layout_toEndOf="@+id/countryNumber"/>
                        </RelativeLayout>
                    </LinearLayout>
                    <LinearLayout android:orientation="vertical" android:background="#979797" android:layout_width="match_parent" android:layout_height="1dp"/>
                    <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="50dp">
                        <RelativeLayout android:layout_width="match_parent" android:layout_height="48dp">
                            <EditText android:textSize="15sp" android:id="@+id/ed_password" android:background="@drawable/shadow_view" android:layout_width="match_parent" android:layout_height="match_parent" android:hint="كلمة السر" android:maxLines="1" android:drawablePadding="8dp" android:inputType="textPassword" android:imeOptions="actionDone" android:drawableStart="@drawable/password_left" android:textAlignment="center" android:paddingStart="8dp" android:paddingEnd="8dp" app:theme="@style/MyEditTextTheme"/>
                            <ImageView android:id="@+id/eye_img" android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_eye_open" android:layout_centerVertical="true" android:layout_marginEnd="9dp" android:layout_alignParentEnd="true"/>
                        </RelativeLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
            <Button android:textStyle="bold" android:textColor="@color/white" android:id="@+id/login_btn" android:background="@drawable/rect_blue" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="30dp" android:layout_marginTop="15sp" android:layout_marginRight="30dp" android:text="تسجيل"/>
            <RelativeLayout android:gravity="center" android:layout_gravity="center" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="10dp" android:layout_marginTop="20sp" android:layout_marginRight="10dp">
                <TextView android:textSize="15dp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/donnot_have_account" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="التسجيل بالبرنامج" android:layout_marginEnd="4dp"/>
                <TextView android:textSize="15dp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/forgot_password" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="نسيت كلمة المرور" android:layout_alignParentEnd="true"/>
            </RelativeLayout>
            <TextView android:textSize="17sp" android:textColor="@color/white" android:gravity="center" android:id="@+id/mykey_btn" android:background="@drawable/round_border" android:layout_width="match_parent" android:layout_height="45dp" android:layout_marginTop="20sp" android:text="عرض الكود" android:layout_marginStart="50sp" android:layout_marginEnd="50sp"/>
        </LinearLayout>
    </RelativeLayout>
</ScrollView>
