<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:lgrupo="http://schemas.android.com/apk/lib/com.blogspot.yemeninfo4it.mumsmobile_app" xmlns:aapt="http://schemas.android.com/aapt" android:orientation="vertical" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layoutDirection="rtl">
    <LinearLayout android:orientation="vertical" android:id="@+id/title" android:layout_width="wrap_content" android:layout_height="wrap_content">
        <LinearLayout android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="wrap_content">
            <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="@color/black" android:id="@+id/at" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="5dp" android:layout_marginRight="5dp" android:minWidth="135dp" android:text="اسم المنفذ" android:layout_weight="0.9"/>
            <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="@color/black" android:id="@+id/bt" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="5dp" android:layout_marginRight="5dp" android:minWidth="130dp" android:text="اسم الاكسس" android:layout_weight="0.8"/>
            <TextView android:textSize="13sp" android:textStyle="bold" android:textColor="@color/black" android:id="@+id/ct" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="6dp" android:layout_marginRight="4dp" android:minWidth="135dp" android:text="ماك ادرس" android:layout_weight="0.9" android:textAlignment="center"/>
            <TextView android:textSize="13sp" android:textStyle="bold" android:textColor="@color/black" android:id="@+id/dt" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="5dp" android:layout_marginRight="7dp" android:minWidth="130dp" android:text="العنوان" android:layout_weight="0.8"/>
        </LinearLayout>
        <View android:id="@+id/vv" android:background="#4b4b4b" android:layout_width="match_parent" android:layout_height="2dp"/>
    </LinearLayout>
    <LinearLayout android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="wrap_content">
        <TextView android:id="@+id/etherinterface" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="5dp" android:layout_marginTop="2dp" android:layout_marginRight="5dp" android:layout_marginBottom="2dp" android:minWidth="135dp" android:text="لا اليوم بيانات" android:layout_weight="0.8" android:textDirection="rtl"/>
        <TextView android:id="@+id/name" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="5dp" android:layout_marginTop="2dp" android:layout_marginRight="5dp" android:layout_marginBottom="2dp" android:minWidth="130dp" android:text="لا من بيانات" android:layout_weight="0.8" android:textDirection="rtl"/>
        <TextView android:id="@+id/mac" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="4dp" android:layout_marginTop="2dp" android:layout_marginRight="6dp" android:layout_marginBottom="2dp" android:minWidth="135dp" android:text="لا الى بيانات" android:layout_weight="0.8" android:textAlignment="center"/>
        <TextView android:id="@+id/ipaddress" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="5dp" android:layout_marginTop="2dp" android:layout_marginRight="7dp" android:layout_marginBottom="2dp" android:minWidth="130dp" android:text="لا الى بيانات" android:layout_weight="0.8"/>
    </LinearLayout>
    <View android:background="#cacaca" android:layout_width="match_parent" android:layout_height="1dp"/>
</LinearLayout>
