<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:lgrupo="http://schemas.android.com/apk/lib/com.blogspot.yemeninfo4it.mumsmobile_app" xmlns:aapt="http://schemas.android.com/aapt" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent" android:fillViewport="true" android:layoutDirection="rtl">
    <RelativeLayout android:background="@drawable/rect_grey" android:focusable="true" android:focusableInTouchMode="true" android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView android:id="@+id/back_img" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="40dp" android:text="ffff"/>
        <ImageView android:id="@+id/app_logo" android:padding="10dp" android:layout_width="170dp" android:layout_height="170dp" android:layout_marginTop="10dp" android:src="@drawable/logonew" android:layout_centerHorizontal="true" android:contentDescription="دخول"/>
        <LinearLayout android:gravity="bottom" android:layout_gravity="bottom" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="30dp" android:layout_marginTop="15dp" android:layout_marginRight="30dp" android:layout_marginBottom="15dp" android:layout_below="@+id/app_logo">
            <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="1dp">
                <RelativeLayout android:background="@drawable/rect" android:layout_width="match_parent" android:layout_height="55dp" android:layout_marginBottom="8dp">
                    <ImageView android:id="@+id/countryImage2" android:layout_width="20dp" android:layout_height="20dp" android:layout_centerVertical="true" android:layout_marginStart="10dp" android:layout_marginEnd="10dp" app:srcCompat="@drawable/ic_user"/>
                    <EditText android:textSize="15dp" android:id="@+id/name" android:background="@null" android:layout_width="match_parent" android:layout_height="match_parent" android:hint="الاسم" android:maxLines="1" android:layout_alignParentBottom="true" android:imeOptions="actionNext" android:textAlignment="center" android:paddingStart="20dp" android:paddingEnd="20dp"/>
                </RelativeLayout>
                <RelativeLayout android:background="@drawable/rect" android:layout_width="match_parent" android:layout_height="55dp">
                    <ImageView android:id="@+id/countryImage" android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/flag_ye" android:layout_centerVertical="true" android:layout_marginStart="10dp"/>
                    <EditText android:enabled="false" android:textSize="12dp" android:gravity="center" android:id="@+id/countryNumber" android:layout_width="wrap_content" android:layout_height="match_parent" android:text="+967" android:layout_alignParentBottom="true" android:layout_marginStart="6dp" android:layout_toEndOf="@+id/countryImage"/>
                    <EditText android:enabled="false" android:textSize="15dp" android:id="@+id/ed_mobile_number" android:background="@null" android:layout_width="match_parent" android:layout_height="match_parent" android:hint="رقم الموبايل" android:maxLines="1" android:layout_alignParentBottom="true" android:inputType="number" android:imeOptions="actionNext" android:textAlignment="center" android:paddingStart="10dp" android:paddingEnd="10dp" android:layout_toEndOf="@+id/countryNumber"/>
                </RelativeLayout>
                <RelativeLayout android:background="@drawable/rect" android:layout_width="match_parent" android:layout_height="55dp" android:layout_marginTop="8dp">
                    <EditText android:textSize="14dp" android:id="@+id/ed_password" android:background="@drawable/shadow_view" android:layout_width="match_parent" android:layout_height="42dp" android:hint="كلمة السر" android:maxLines="1" android:drawablePadding="8dp" android:inputType="textPassword" android:imeOptions="actionDone" android:drawableStart="@drawable/password_left" android:textAlignment="center" android:paddingStart="8dp" android:paddingEnd="8dp" app:theme="@style/MyEditTextTheme"/>
                    <ImageView android:id="@+id/eye_img" android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_eye_open" android:layout_centerVertical="true" android:layout_marginEnd="9dp" android:layout_alignParentEnd="true"/>
                </RelativeLayout>
                <Button android:textStyle="bold" android:textColor="@color/white" android:id="@+id/login_btn" android:background="@drawable/rect_blue" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="20dp" android:layout_marginTop="30dp" android:layout_marginRight="20dp" android:text="تسجيل"/>
                <RelativeLayout android:gravity="center" android:layout_gravity="center" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="10dp" android:layout_marginTop="30dp" android:layout_marginRight="10dp">
                    <TextView android:textSize="14dp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/have_account" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="لديك حساب بالفعل؟" android:layout_marginEnd="4dp"/>
                    <TextView android:textSize="14dp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/forgot_password" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="نسيت كلمة المرور" android:layout_alignParentEnd="true"/>
                </RelativeLayout>
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>
</ScrollView>
