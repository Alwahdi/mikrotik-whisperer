<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:lgrupo="http://schemas.android.com/apk/lib/com.blogspot.yemeninfo4it.mumsmobile_app" xmlns:aapt="http://schemas.android.com/aapt" android:orientation="vertical" android:id="@+id/data_layout" android:layout_width="match_parent" android:layout_height="wrap_content" android:layoutDirection="rtl">
    <LinearLayout android:orientation="vertical" android:background="@drawable/btn_orange_2" android:padding="4dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="3dp" android:elevation="3dp">
        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="1dp">
            <TextView android:id="@+id/port" android:paddingTop="3dp" android:paddingBottom="3dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:layout_marginBottom="2dp" android:text="............" android:layout_weight="2" android:textAlignment="textEnd"/>
            <TextView android:id="@+id/ipaddress" android:paddingTop="3dp" android:paddingBottom="3dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:layout_marginBottom="2dp" android:minWidth="135dp" android:layout_weight="0.5" android:textDirection="rtl" android:textAlignment="center"/>
        </LinearLayout>
        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:id="@+id/password" android:paddingTop="3dp" android:paddingBottom="3dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:layout_marginBottom="2dp" android:text="............" android:layout_weight="1" android:textAlignment="center"/>
            <TextView android:id="@+id/name" android:paddingTop="5dp" android:paddingBottom="5dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:layout_marginBottom="2dp" android:text="............" android:layout_weight="1" android:textAlignment="center" android:layout_marginStart="3dp" android:layout_marginEnd="3dp"/>
        </LinearLayout>
        <TextView android:id="@+id/desc" android:paddingTop="3dp" android:paddingBottom="3dp" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:layout_marginBottom="2dp" android:text="............" android:textAlignment="center"/>
    </LinearLayout>
</LinearLayout>
