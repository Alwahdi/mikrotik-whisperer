<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:lgrupo="http://schemas.android.com/apk/lib/com.blogspot.yemeninfo4it.mumsmobile_app" xmlns:aapt="http://schemas.android.com/aapt" android:orientation="vertical" android:id="@+id/bottom_sheet" android:background="@drawable/shape_login_bottom_sheet" android:layout_width="match_parent" android:layout_height="400dp" android:layoutDirection="rtl" app:behavior_hideable="true" app:behavior_peekHeight="45dp" app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">
    <LinearLayout android:gravity="top" android:layout_gravity="top" android:background="@drawable/rect_dotted" android:padding="0dp" android:layout_width="match_parent" android:layout_height="45dp">
        <LinearLayout android:gravity="center" android:layout_gravity="center" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="20sp" android:layout_marginEnd="20dp">
            <LinearLayout android:layout_width="25dp" android:layout_height="wrap_content">
                <ImageView android:id="@+id/bottom_shet_close" android:visibility="gone" android:layout_width="23dp" android:layout_height="23dp" android:layout_marginTop="7dp" android:layout_marginBottom="10dp" app:srcCompat="@drawable/ic_close"/>
            </LinearLayout>
            <TextView android:textSize="18sp" android:textStyle="bold" android:textColor="@color/white" android:gravity="center" android:layout_gravity="center" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:layout_marginBottom="5dp" android:text="سجلات الدخول" android:layout_weight="1"/>
            <ImageView android:id="@+id/bottom_shet_down_up" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="7dp" android:layout_marginBottom="7dp" android:layout_marginEnd="10dp" app:srcCompat="@drawable/ic_up"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout android:gravity="center" android:id="@+id/recorde_found" android:layout_width="match_parent" android:layout_height="match_parent" android:paddingStart="10dp" android:paddingEnd="10dp">
        <androidx.recyclerview.widget.RecyclerView android:scrollbarStyle="outsideOverlay" android:layout_gravity="top" android:id="@+id/recycler_logindata" android:paddingBottom="5dp" android:scrollbars="none|horizontal|vertical" android:clickable="true" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginLeft="2dp" android:layout_marginRight="2dp" android:minHeight="250dp" android:nestedScrollingEnabled="true" app:reverseLayout="true"/>
    </LinearLayout>
    <LinearLayout android:gravity="center" android:layout_gravity="center" android:id="@+id/no_recorde" android:visibility="gone" android:layout_width="match_parent" android:layout_height="match_parent" android:paddingStart="10dp" android:paddingEnd="10dp">
        <TextView android:textSize="20sp" android:textStyle="bold" android:textColor="@color/black" android:gravity="center" android:layout_gravity="center" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="20dp" android:text="لا توجد سجلات الدخول"/>
    </LinearLayout>
</LinearLayout>
