<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:lgrupo="http://schemas.android.com/apk/lib/com.blogspot.yemeninfo4it.mumsmobile_app" xmlns:aapt="http://schemas.android.com/aapt" android:id="@+id/fragment_container" android:focusableInTouchMode="true" android:layout_width="match_parent" android:layout_height="match_parent" android:layoutDirection="rtl">
    <LinearLayout android:gravity="center" android:orientation="vertical" android:id="@+id/table_test_container" android:paddingBottom="20dp" android:layout_width="match_parent" android:layout_height="wrap_content">
        <include layout="@layout/toolbar_act"/>
        <com.blogspot.yemeninfo4it.mumsmobile_app.MyHorizScrollView android:scrollbarTrackHorizontal="@color/mainColor" android:scrollbarStyle="insideInset" android:gravity="center" android:layout_gravity="center" android:visibility="gone" android:scrollbars="none|horizontal|vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
            <LinearLayout android:layout_gravity="center" android:orientation="horizontal" android:id="@+id/search_field" android:paddingBottom="10dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="5dp" android:layout_marginTop="10dp" android:layout_marginRight="5dp" android:weightSum="100">
                <Button android:textSize="16.5sp" android:textStyle="bold" android:textColor="#ffffff" android:id="@+id/activebtn" android:background="@drawable/rect_blue" android:paddingLeft="22dp" android:paddingRight="22dp" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:layout_marginBottom="5dp" android:text="تحميل" android:onClick="clickgoo" android:textAllCaps="false"/>
                <Button android:textSize="16.5sp" android:textStyle="bold" android:textColor="#ffffff" android:id="@+id/showbtn" android:background="@drawable/rect_blue" android:paddingLeft="22dp" android:paddingRight="22dp" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:layout_marginBottom="5dp" android:text="إظهار" android:textAllCaps="false"/>
                <Button android:textSize="16.5sp" android:textStyle="bold" android:textColor="#ffffff" android:id="@+id/dubl" android:background="@drawable/rect_blue" android:paddingLeft="20dp" android:paddingRight="20dp" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:layout_marginBottom="5dp" android:text="حذف التكرار" android:textAllCaps="false"/>
            </LinearLayout>
        </com.blogspot.yemeninfo4it.mumsmobile_app.MyHorizScrollView>
        <LinearLayout android:gravity="center" android:layout_gravity="center" android:orientation="horizontal" android:id="@+id/dates_layout2" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:weightSum="100">
            <TextView android:textSize="16sp" android:textStyle="bold" android:textColor="@color/black" android:id="@+id/start_date" android:background="@drawable/btn_checked" android:paddingTop="4dp" android:paddingBottom="4dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="80dp" android:text="من تاريخ" android:textAlignment="center" android:paddingStart="8dp" android:paddingEnd="8dp" android:elevation="2sp"/>
            <TextView android:textSize="17sp" android:textStyle="bold" android:textColor="@color/black" android:padding="10dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" الــــى "/>
            <TextView android:textSize="16sp" android:textStyle="bold" android:textColor="@color/black" android:id="@+id/end_date" android:background="@drawable/btn_checked" android:paddingTop="4dp" android:paddingBottom="4dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="80dp" android:text="تاريـــخ" android:textAlignment="center" android:paddingStart="8dp" android:paddingEnd="8dp" android:elevation="2sp"/>
        </LinearLayout>
        <LinearLayout android:gravity="center" android:layout_gravity="center" android:orientation="horizontal" android:id="@+id/ether_layout" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp">
            <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="@color/black" android:paddingTop="4dp" android:paddingBottom="5dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="المنفذ" android:textAlignment="center" android:layout_marginStart="5sp" android:layout_marginEnd="0sp"/>
            <Spinner android:textSize="14sp" android:textColor="@color/white" android:gravity="center_vertical" android:id="@+id/ether_name" android:background="@drawable/rect" android:padding="7dp" android:layout_width="0dp" android:layout_height="35sp" android:layout_marginTop="5dp" android:layout_marginBottom="5dp" android:singleLine="true" android:layout_weight="1" android:spinnerMode="dialog" android:layout_marginStart="3sp" android:layout_marginEnd="3sp"/>
            <TextView android:textSize="13sp" android:textStyle="bold" android:textColor="@color/mainColorDark" android:id="@+id/load_myprofile" android:paddingTop="0dp" android:paddingBottom="5dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="تحميل" android:textAlignment="center" android:layout_marginStart="0sp" android:layout_marginEnd="0sp"/>
            <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="@color/black" android:paddingTop="4dp" android:paddingBottom="5dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="السعر" android:textAlignment="center" android:layout_marginStart="5sp" android:layout_marginEnd="0sp"/>
            <Spinner android:textSize="14sp" android:textColor="@color/white" android:gravity="center_vertical" android:id="@+id/price_list" android:background="@drawable/rect" android:padding="7dp" android:layout_width="0dp" android:layout_height="35sp" android:layout_marginTop="5dp" android:layout_marginBottom="5dp" android:singleLine="true" android:layout_weight="1" android:spinnerMode="dialog" android:layout_marginStart="3sp" android:layout_marginEnd="3sp"/>
        </LinearLayout>
        <LinearLayout android:gravity="center" android:layout_gravity="center" android:orientation="horizontal" android:id="@+id/dates_layout" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:weightSum="100">
            <TextView android:textSize="15sp" android:textStyle="bold" android:textColor="@color/black" android:id="@+id/sum" android:padding="4dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="المجموع"/>
            <TextView android:textSize="15sp" android:textStyle="bold" android:textColor="@color/black" android:id="@+id/activeacount" android:padding="4dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="العدد"/>
        </LinearLayout>
        <LinearLayout android:gravity="center" android:layout_gravity="center" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="1dp">
            <TextView android:textSize="15sp" android:textStyle="bold" android:textColor="@color/black" android:id="@+id/transmit_sum" android:padding="2dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="مجموع التحميل+الرفع:0"/>
        </LinearLayout>
        <HorizontalScrollView android:id="@+id/horizontalView" android:visibility="gone" android:scrollbars="none|horizontal|vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
            <LinearLayout android:gravity="center" android:orientation="horizontal" android:background="@drawable/btn_back" android:layout_width="wrap_content" android:layout_height="wrap_content">
                <TextView android:textSize="14dp" android:textStyle="bold" android:textColor="@color/black" android:padding="10dp" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="80dp" android:text="ID"/>
                <TextView android:textSize="14dp" android:textStyle="bold" android:textColor="@color/black" android:padding="10dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="80dp" android:text="اسم المستخدم"/>
                <TextView android:textSize="14dp" android:textStyle="bold" android:textColor="@color/black" android:padding="10dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="80dp" android:text="مدة الاتصال"/>
                <TextView android:textSize="14dp" android:textStyle="bold" android:textColor="@color/black" android:padding="10dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="80dp" android:text="الوقت المتبقي"/>
                <TextView android:textSize="14dp" android:textStyle="bold" android:textColor="@color/black" android:padding="10dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="80dp" android:text="ايبي"/>
                <TextView android:textSize="14dp" android:textStyle="bold" android:textColor="@color/black" android:padding="10dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="80dp" android:text="تحميل"/>
                <TextView android:textSize="14dp" android:textStyle="bold" android:textColor="@color/black" android:padding="10dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="80dp" android:text="الرفع"/>
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>
    <com.evrencoskun.tableview.TableView android:gravity="center" android:layout_gravity="center" android:id="@+id/tableview" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_below="@+id/table_test_container" app:selected_color="@color/colorPrimaryDark" app:shadow_color="#eee" app:unselected_color="@color/white"/>
    <androidx.recyclerview.widget.RecyclerView android:scrollbarStyle="outsideOverlay" android:id="@+id/recycleractive" android:paddingBottom="5dp" android:visibility="gone" android:scrollbars="none|horizontal|vertical" android:clickable="true" android:layout_width="match_parent" android:layout_height="270dp" android:layout_marginLeft="2dp" android:layout_marginRight="2dp" android:minHeight="250dp" android:nestedScrollingEnabled="true" app:reverseLayout="true"/>
</RelativeLayout>
