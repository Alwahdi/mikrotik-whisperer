<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:lgrupo="http://schemas.android.com/apk/lib/com.blogspot.yemeninfo4it.mumsmobile_app" xmlns:aapt="http://schemas.android.com/aapt" android:id="@+id/coordinateLayout" android:background="@drawable/rect_grey" android:padding="0dp" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" android:layoutDirection="rtl">
    <RelativeLayout android:padding="0dp" android:layout_width="match_parent" android:layout_height="match_parent">
