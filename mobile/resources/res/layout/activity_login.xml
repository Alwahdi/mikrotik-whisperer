                        <TextView android:textSize="12sp" android:textColor="#ffffff" android:paddingLeft="5dp" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Get help signing in."/>
                    </LinearLayout>
                </LinearLayout>
