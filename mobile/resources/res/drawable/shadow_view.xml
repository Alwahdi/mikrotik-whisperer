<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="0dp"/>
        </shape>
    </item>
    <gradient android:startColor="#2f000000" android:endColor="#2f000000" android:angle="270"/>
    <item android:left="0dp" android:top="0dp" android:right="0dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/white"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
</layer-list>
